# ==============================================
# Plataformamatreiro - Environment Variables
# ==============================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES

# Django
DEBUG=False
SECRET_KEY=YOUR_SECRET_KEY_HERE
ALLOWED_HOSTS=localhost,127.0.0.1,YOUR_DOMAIN_OR_IP

# Database (PostgreSQL local via Docker)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=matreiro_db
DB_USER=matreiro_user
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_HOST=postgres
DB_PORT=5432

# Keycloak (Opcional - para produção com auth real)
KEYCLOAK_URL=https://iam.upn.com.br/auth
KEYCLOAK_REALM=matreiro
KEYCLOAK_CLIENT_ID=Matreiro

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://YOUR_DOMAIN_OR_IP,http://127.0.0.1

# Email (Opcional)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DEFAULT_FROM_EMAIL=phishing@underprotection.com.br
